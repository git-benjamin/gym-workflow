# Copy to terraform.tfvars and fill in values. Never commit terraform.tfvars.

supabase_db_host     = "db.<ref>.supabase.co"
supabase_db_password = "your-postgres-password"
supabase_url         = "https://<ref>.supabase.co"
supabase_service_key = "your-service-role-key"
supabase_bucket      = "hevy-analytics"
supabase_s3_endpoint = "https://<ref>.supabase.co/storage/v1/s3"
supabase_s3_key      = "your-s3-access-key-id"
supabase_s3_secret   = "your-s3-secret-key"
supabase_s3_region   = "ap-southeast-2"

cloudflare_api_token  = "your-cloudflare-api-token"
cloudflare_account_id = "your-cloudflare-account-id"
hevy_webhook_auth     = "Bearer your-random-secret"

github_token = "github_pat_..."
github_owner = "benjamindang"
github_repo  = "gym-workflow"

hevy_api_key      = "your-hevy-api-key"
anthropic_api_key = "sk-ant-..."
